# ─────────────────────────────────────────────────────────────────────────────
# Doppler is the primary secret source for this project.
# Project: open-banking-chile  |  Configs: dev (local), prd (Vercel via integration)
#
# To run locally:
#   doppler run --project open-banking-chile --config dev -- npm run dev
#
# This file is only needed if you're running WITHOUT Doppler.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — project "open-banking" (https://wcyxlyitcbmeczihaohq.supabase.co)
# Find keys in: Supabase dashboard → project open-banking → Settings → API
SUPABASE_URL=https://wcyxlyitcbmeczihaohq.supabase.co
SUPABASE_ANON_KEY=

# Auth.js — canonical URL must match the OAuth redirect URI in Google Console
# Google Cloud project: open-banking-chile
# Authorized redirect URIs:
#   http://localhost:3434/api/auth/callback/google       (dev)
#   https://open-banking-chile.vercel.app/api/auth/callback/google  (prd)
AUTH_URL=http://localhost:3434
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=       # generate: openssl rand -base64 32

# Bank credential encryption — 64-char hex string (32 raw bytes)
CREDENTIALS_SECRET=  # generate: openssl rand -hex 32
