# Auth.js
AUTH_SECRET=                  # generate with: openssl rand -base64 32
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Auth.js v5 canonical URL (must match OAuth callback URL in Google Console)
AUTH_URL=http://localhost:3434

# Supabase (HTTP client — required for all DB access)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Credential encryption — 64-char hex string (32 raw bytes)
# generate with: openssl rand -hex 32
CREDENTIALS_SECRET=
