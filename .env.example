# Tu RUT sin puntos ni guión (ej: 123456789)
FALABELLA_RUT=123456789
BICE_RUT=123456789
SANTANDER_RUT=123456789

# Tu clave de internet del banco
FALABELLA_PASS=tu_clave_aqui
BICE_PASS=tu_clave_aqui
SANTANDER_PASS=tu_clave_aqui
# Opcional [SANTANDER]: segundos máximos para esperar aprobación manual de 2FA (default: 180)
# SANTANDER_2FA_TIMEOUT_SEC=240
# Opcional [BICE]: cantidad de periodos historicos adicionales a consultar (default: 0 = solo mes actual). Debe ser un valor entre 1 y 16
# BICE_MONTHS=3

# Opcional: ruta al ejecutable de Chrome/Chromium
# CHROME_PATH=/usr/bin/google-chrome-stable
