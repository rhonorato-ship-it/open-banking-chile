# Tu RUT sin puntos ni guión (ej: 123456789)
FALABELLA_RUT=123456789
BICE_RUT=123456789
SANTANDER_RUT=123456789
EDWARDS_RUT=123456789
BCI_RUT=123456789
ITAU_RUT=123456789
BANCOCHILE_RUT=123456789
BCHILE_RUT=123456789
SCOTIABANK_RUT=123456789
BESTADO_RUT=123456789

# Tu clave de internet del banco
FALABELLA_PASS=tu_clave_aqui
BICE_PASS=tu_clave_aqui
SANTANDER_PASS=tu_clave_aqui
EDWARDS_PASS=tu_clave_aqui
BCI_PASS=tu_clave_aqui
ITAU_PASS=tu_clave_aqui
BANCOCHILE_PASS=tu_clave_aqui
BCHILE_PASS=tu_clave_aqui
SCOTIABANK_PASS=tu_clave_aqui
BESTADO_PASS=tu_clave_aqui

# Opcional [FALABELLA]: filtro TC por titular/adicional (T=titular, A=adicional, B=todos, default: B)
# FALABELLA_OWNER=B
# Opcional [SCOTIABANK]:
# SCOTIABANK_MONTHS=3
# Opcional [BCHILE]: segundos máximos para esperar aprobación manual de 2FA (default: 180)
# BCHILE_2FA_TIMEOUT_SEC=240
# Opcional [SANTANDER]: segundos máximos para esperar aprobación manual de 2FA (default: 180)
# SANTANDER_2FA_TIMEOUT_SEC=240
# Opcional [BCI]: segundos máximos para esperar aprobación manual de 2FA (default: 180)
# BCI_2FA_TIMEOUT_SEC=240
# Opcional [ITAU]: segundos máximos para esperar aprobación manual de 2FA Itaú Key (default: 180)
# ITAU_2FA_TIMEOUT_SEC=240
# Opcional [BICE]: cantidad de periodos historicos adicionales a consultar (default: 0 = solo mes actual). Debe ser un valor entre 1 y 16
# BICE_MONTHS=3

# Opcional: ruta al ejecutable de Chrome/Chromium
# CHROME_PATH=/usr/bin/google-chrome-stable

# ── Google Drive (requerido para --sync-drive) ─────────────────
# ID de la carpeta de Google Drive donde se guardarán los archivos
# Encuéntralo en la URL de la carpeta: drive.google.com/drive/folders/<ID>
GOOGLE_DRIVE_FOLDER_ID=

# Opción 1: Ruta al archivo JSON de la cuenta de servicio de Google
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/ruta/a/service-account.json

# Opción 2: Contenido JSON de la cuenta de servicio como string (para Docker)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Cómo crear una cuenta de servicio:
# 1. Ve a console.cloud.google.com → IAM → Cuentas de servicio
# 2. Crea una cuenta de servicio y descarga el JSON
# 3. Comparte la carpeta de Drive con el email de la cuenta de servicio
